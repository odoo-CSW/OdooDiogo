<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

    <!-- Herdar o formulário de registro de pagamento -->
    <record id="view_account_payment_register_form_MBWAY_paypal" model="ir.ui.view">
        <field name="name">account.payment.register.form.MBWAY.paypal</field>
        <field name="model">account.payment.register</field>
        <field name="inherit_id" ref="account.view_account_payment_register_form"/>
        <field name="arch" type="xml">
            
            <!-- Campo invisível para controlar visibilidade -->
            <xpath expr="//field[@name='payment_method_line_id']" position="after">
                <field name="payment_method_code" invisible="1"/>
            </xpath>
            
            <!-- Campo MB WAY -->
            <xpath expr="//field[@name='payment_method_code']" position="after">
                <field name="x_mbway_phone" 
                       string="Número MB WAY" 
                       placeholder="9XX XXX XXX" 
                       widget="phone"
                       invisible="payment_method_code != 'MBWAY'" 
                       required="payment_method_code == 'MBWAY'"/>
            </xpath>
            
            <!-- Campo PayPal -->
            <xpath expr="//field[@name='payment_method_code']" position="after">
                <field name="x_paypal_email" 
                       string="E-mail PayPal" 
                       placeholder="ex: cliente@dominio.com"
                       widget="email"
                       invisible="payment_method_code != 'paypal'"
                       required="payment_method_code == 'paypal'"/>
            </xpath>

        </field>
    </record>

    </data>
</odoo>
