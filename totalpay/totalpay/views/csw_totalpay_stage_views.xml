<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
    <!-- MENU -->

    <menuitem id="menu_csw_stages"
              name="Estados Pagamento"
              parent="menu_csw_root"
              action="action_x_csw_totalpay_stage"
              groups="totalpay.group_admin"
              sequence="20"/>


    <!-- VIEWS: ESTADOS -->

    <!-- Form View: Estados -->
    <record id="view_x_csw_totalpay_stage_form" model="ir.ui.view">
        <field name="name">x_csw_totalpay_stage.form</field>
        <field name="model">x_csw_totalpay_stage</field>
        <field name="arch" type="xml">
            <form string="Estado Pagamento" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <field name="x_name" readonly="1" string="Estado Pagamento"/>
                        <field name="id" readonly="1" string="ID"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View: Estados -->
    <record id="view_x_csw_totalpay_stage_list" model="ir.ui.view">
        <field name="name">x_csw_totalpay_stage.list</field>
        <field name="model">x_csw_totalpay_stage</field>
        <field name="arch" type="xml">
                <list string="Estados Pagamento" create="false" edit="false" delete="false">
                <field name="x_studio_sequence" widget="handle"/>
                <field name="x_name"/>
            </list>
        </field>
    </record>

    </data>
</odoo>
